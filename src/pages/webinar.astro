---
import BaseLayout from "../layouts/BaseLayout.astro";
import RegisterForm from "../components/RegisterForm.astro";
import Icon from "../components/Icon.astro";
import { SITE } from "../config/site";
const w = SITE.webinar;

const eventSchema = [{
  "@context": "https://schema.org",
  "@type": "Event",
  name: w.title,
  description: w.subtitle,
  eventAttendanceMode: "https://schema.org/OnlineEventAttendanceMode",
  eventStatus: "https://schema.org/EventScheduled",
  organizer: { "@type": "Organization", name: SITE.name, url: SITE.url },
  performer: { "@type": "Person", name: w.host },
  location: { "@type": "VirtualLocation", url: SITE.url + "/webinar" },
}];
---
<BaseLayout
  title={`${w.title} — free masterclass for contractors | SotynERP`}
  description={`${w.subtitle} A free live masterclass by ${w.host}. ${w.seats}. Register now.`}
  path="/webinar"
  schema={eventSchema}
>
  <!-- HERO + REGISTER -->
  <section class="wh">
    <div class="container wh__in">
      <div class="wh__copy">
        <span class="pill"><Icon name="bolt" size={15} /> {w.kicker}</span>
        <h1>{w.title}</h1>
        <p class="lead">{w.subtitle}</p>
        <div class="wh__meta">
          <span><Icon name="check" size={16} /> {w.when}</span>
          <span><Icon name="check" size={16} /> {w.duration}</span>
          <span><Icon name="check" size={16} /> {w.platform}</span>
          <span><Icon name="check" size={16} /> {w.seats}</span>
        </div>
        <ul class="wh__learn">
          {w.learn.map((l) => <li><Icon name="check" size={18} /> {l}</li>)}
        </ul>
      </div>

      <div class="wh__form" id="register">
        <div class="wh__formhead">
          <strong>Reserve your free seat</strong>
          <span>{w.seats} · no cost, no recording sent</span>
        </div>
        <RegisterForm source="webinar-page" />
      </div>
    </div>
  </section>

  <!-- WHO IT'S FOR -->
  <section class="strip2">
    <div class="container text-center">
      <p>Built for <strong>{w.forWho}</strong></p>
    </div>
  </section>

  <!-- HOST (business coach authority) -->
  <section class="section">
    <div class="container host">
      <img class="host__photo" src="/images/founder-ankur-kaplesh.jpg" alt={w.host} width="638" height="720" loading="lazy" />
      <div class="host__copy">
        <span class="eyebrow">Your host</span>
        <h2>{w.host}</h2>
        <p class="host__title">{w.hostTitle}</p>
        <p>Ankur has spent 14 years building a contracting business from the ground up — 535+ projects across 18 states, run by 300+ people on a system he built himself. He's a TEDx speaker and author of two books on where Indian projects lose money. In this masterclass he teaches the exact playbook — not theory, the real numbers and systems from a live EPC business.</p>
        <div class="host__books">
          <img src="/images/book-11-deadly-facts.jpg" alt="11 Deadly Facts (book)" width="964" height="1500" loading="lazy" />
          <img src="/images/book-autocad-to-site.jpg" alt="From AutoCAD to Actual Site (book)" width="551" height="780" loading="lazy" />
          <div class="host__stats">
            {SITE.stats.map((s) => (<div><strong>{s.value}</strong><span>{s.label}</span></div>))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="section section--dark text-center">
    <div class="container container--narrow">
      <h2>Your competitors are plugging these leaks. Are you?</h2>
      <p class="lead" style="margin-inline:auto">It's free, it's live, and the seats are limited. Spend 60 minutes — leave knowing exactly where your money is going.</p>
      <div class="btn-row" style="justify-content:center;margin-top:26px">
        <a href="#register" class="btn btn--primary btn--lg">Reserve my free seat</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .wh { background: linear-gradient(180deg, var(--brand-50), #fff 60%); padding: clamp(40px, 6vw, 72px) 0 clamp(48px, 7vw, 80px); border-bottom: 1px solid var(--line); }
  .wh__in { display: grid; grid-template-columns: 1.1fr .9fr; gap: 48px; align-items: start; }
  .wh__copy h1 { margin: 16px 0 14px; font-size: clamp(2.1rem, 4.6vw, 3.4rem); }
  .wh__meta { display: flex; flex-wrap: wrap; gap: 10px 18px; margin: 22px 0; }
  .wh__meta span { display: inline-flex; align-items: center; gap: 7px; font-weight: 700; font-size: .92rem; color: var(--graphite-800); }
  .wh__meta :global(.ico) { color: var(--brand-600); }
  .wh__learn { list-style: none; display: grid; gap: 12px; margin-top: 6px; }
  .wh__learn li { display: flex; align-items: flex-start; gap: 11px; font-size: 1.02rem; color: var(--body); }
  .wh__learn :global(.ico) { color: var(--brand-600); flex: none; margin-top: 3px; }

  .wh__form { background: #fff; border: 1px solid var(--line); border-radius: var(--radius); padding: 26px; box-shadow: var(--shadow-lg); position: sticky; top: 96px; }
  .wh__formhead { margin-bottom: 16px; }
  .wh__formhead strong { display: block; font-size: 1.25rem; color: var(--ink); }
  .wh__formhead span { font-size: .85rem; color: var(--muted); }

  .strip2 { background: var(--graphite-900); color: #cbd5e1; padding: 20px 0; }
  .strip2 p { margin: 0; font-size: 1.02rem; }
  .strip2 strong { color: #fff; }

  .host { display: grid; grid-template-columns: auto 1fr; gap: 40px; align-items: start; }
  .host__photo { width: 200px; height: 240px; object-fit: cover; object-position: top center; border-radius: 20px; box-shadow: var(--shadow-lg); flex: none; }
  .host__copy h2 { margin-bottom: 4px; }
  .host__title { font-weight: 700; color: var(--brand-700); margin-bottom: 14px; }
  .host__books { display: flex; align-items: center; gap: 16px; margin-top: 22px; flex-wrap: wrap; }
  .host__books img { height: 120px; width: auto; border-radius: 8px; box-shadow: var(--shadow); }
  .host__stats { display: grid; grid-template-columns: 1fr 1fr; gap: 12px 22px; }
  .host__stats strong { display: block; font-size: 1.5rem; font-weight: 900; color: var(--brand-700); letter-spacing: -.02em; }
  .host__stats span { font-size: .78rem; color: var(--muted); }

  @media (max-width: 900px) {
    .wh__in { grid-template-columns: 1fr; gap: 32px; }
    .wh__form { position: static; }
    .host { grid-template-columns: 1fr; gap: 24px; justify-items: center; text-align: center; }
    .host__books { justify-content: center; }
    .host__stats { text-align: left; }
  }
</style>
