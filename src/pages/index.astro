---
import BaseLayout from "../layouts/BaseLayout.astro";
import DemoForm from "../components/DemoForm.astro";
import BookLeadMagnet from "../components/BookLeadMagnet.astro";
import Icon from "../components/Icon.astro";
import Countdown from "../components/Countdown.astro";
import { SITE, waLink } from "../config/site";

// ── The 4 money questions every contractor asks ─────────────────────────────
const leaks = [
  {
    q: "Where am I losing money?",
    icon: "trending-down",
    leak: "Margin dies at the quote — you win jobs you actually lose money on, and only find out months later.",
    plug: "Every quote shows real margin before you send it.",
    modules: ["AI Auto-Quotation", "Estimator", "Price Breakup Master", "Rate Masters"],
  },
  {
    q: "Where is the leakage going on?",
    icon: "droplet",
    leak: "Material bought above market, ghost labour on muster rolls, inflated sub-contractor bills — the classic three EPC leaks.",
    plug: "Rate-compared purchasing, real attendance, sub-contractor bills checked against agreed rates.",
    modules: ["RFQ Queue", "Vendors", "Attendance", "Sub-contractor Master", "Indent Labour Payment"],
  },
  {
    q: "Where am I facing issues?",
    icon: "alert",
    leak: "Rework, snags and delays — the silent profit-killers you only discover at month-end, when it's too late to fix.",
    plug: "Every site on one screen, updated daily. Problems surface the same day.",
    modules: ["Daily Reports (DPR)", "Snags", "Checklists", "Schedule (Gantt)", "War Room"],
  },
  {
    q: "Why am I not growing?",
    icon: "trending-up",
    leak: "You ARE the system. Every decision waits for you, so the business can't grow past what one person can hold in their head.",
    plug: "A control tower with the numbers, so you can delegate with confidence and take on more work.",
    modules: ["Executive Dashboard", "CRM Sales Funnel", "Delegations", "Scorecard"],
  },
];

// ── Full module map (grouped) — pulled from the live ERP ────────────────────
const moduleGroups = [
  { name: "Sales & CRM", icon: "target", items: ["Leads & CRM Funnel", "AI Auto-Quotation", "Estimator", "Quotations & Orders", "Customers", "Solar Sales Funnel"] },
  { name: "Finance & Cash", icon: "wallet", items: ["Sales Billing & Invoices", "AR/AP Tracker", "Collections", "Cash Flow", "Cheques", "Expenses", "Tally link"] },
  { name: "Procurement & Stock", icon: "box", items: ["RFQ Queue", "Vendors", "Indent → Dispatch", "Inventory", "Item Master", "Tool & Room Rentals", "Assets"] },
  { name: "Site Execution", icon: "building", items: ["Daily Reports (DPR)", "Checklists", "Snags", "PMS Tasks", "Schedule (Gantt)", "Full Kitting", "Fire NOC Renewal"] },
  { name: "People & Labour", icon: "users", items: ["HRMS & Employees", "Attendance", "Payroll", "Hiring & Onboarding", "Training", "Labour Rate", "Sub-contractor Hiring"] },
  { name: "Owner's Control Tower", icon: "gauge", items: ["Executive Dashboard", "War Room", "Operating Console", "Delegations", "Scorecard", "Champions League", "Audit Log"] },
];

// Real names the parent EPC company has delivered for (social proof).
const clients = ["Airtel", "Dabur", "Indian Army", "Fortis", "Hyatt"];

// Credentials (real, from the company profile).
const creds = ["14+ years in business", "ISO 9001:2015", "MSME certified", "18+ states", "300+ users daily"];

const how = [
  { n: "1", t: "Free demo on your numbers", d: "A 20-minute walkthrough using your trades and your project sizes — not a generic slideshow." },
  { n: "2", t: "We set up your masters", d: "Your rates, items, vendors and team are loaded in. We migrate from your spreadsheets and Tally." },
  { n: "3", t: "Your team goes live", d: "Mobile-first, in plain language, on the same app 300+ people already use every day. Training included." },
  { n: "4", t: "You watch the leaks close", d: "Within weeks you can see margin, cash and site status on one screen — and act before money is lost." },
];

const faqs = [
  { q: "Will it fit my kind of EPC work?", a: "Yes. sotyn.ai is built only for EPC contractors — and the same lifecycle (engineer & quote → procure → construct → bill → collect) fits every discipline: MEP, HVAC, electrical, plumbing, fire, solar, civil, industrial and turnkey EPC." },
  { q: "Is my data safe and separate from yours?", a: "Yes. Each company runs in its own secure workspace, hosted in India, with role-based access and a full audit log. Your data is yours — never shared with us or any other contractor." },
  { q: "We already use Tally and Excel. Do we throw them away?", a: "No. sotyn.ai links with Tally and we migrate your existing masters and spreadsheets during setup, so you start with your real data, not a blank slate." },
  { q: "Will my site team actually use it?", a: "It's mobile-first and in plain language — 300+ people, including site staff, use it daily in our own company. Daily reports, attendance and snags are designed for the phone in a worker's pocket." },
  { q: "How much does it cost?", a: "Pricing is tailored to your team size. Book a free demo and we'll quote you on exactly the modules you need — start small and add as you grow." },
];

const faqSchema = [{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({ "@type": "Question", name: f.q, acceptedAnswer: { "@type": "Answer", text: f.a } })),
}];
---
<BaseLayout
  title="sotyn.ai — The AI-powered ERP for EPC contractors | India"
  description="See exactly where your EPC business is losing money — from quote to site to collection. sotyn.ai is the AI-powered ERP built only for EPC contractors across India. Built and run by a live EPC company. Book a free demo."
  schema={faqSchema}
>
  <!-- ── HERO ─────────────────────────────────────────────────────────── -->
  <section class="hero">
    <div class="container hero__in">
      <span class="pill"><Icon name="bolt" size={15} /> India’s first AI ERP built only for EPC contractors</span>
      <h1>Run your entire EPC business on one <span class="hl">AI-powered</span> system.</h1>
      <p class="hero__rotator" aria-live="polite"><span data-rotate>Won the bid. Lost the margin. Found out at month-end.</span></p>
      <p class="lead">
        From the first lead to the final rupee collected — quoting, procurement, site, labour,
        billing and cash. {SITE.name} is the AI-powered ERP built <strong>only for EPC contractors</strong>:
        it shows you exactly where your money leaks, and helps you plug it.
      </p>
      <div class="btn-row">
        <a href="#demo" class="btn btn--primary btn--lg">Book a free demo</a>
        <a href="#leaks" class="btn btn--ghost btn--lg">See where you’re losing money</a>
      </div>
      <div class="hero__stats">
        {SITE.stats.map((s) => (
          <div class="hero__stat"><strong>{s.value}</strong><span>{s.label}</span></div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── SOCIAL PROOF: client names ───────────────────────────────────── -->
  <section class="clients">
    <div class="container">
      <p class="clients__label">Proven on 535+ real projects delivered for India’s biggest names</p>
      <div class="clients__row">
        {clients.map((c) => <span class="clients__name">{c}</span>)}
        <span class="clients__more">+ 500&nbsp;more</span>
      </div>
    </div>
  </section>

  <!-- ── TRUST STRIP ──────────────────────────────────────────────────── -->
  <section class="strip">
    <div class="container strip__in">
      <p>Not built by a software company guessing what contractors need —</p>
      <p class="strip__big">it runs <strong>{SITE.parentCompany}</strong> every single day.</p>
    </div>
  </section>

  <!-- ── SOUND FAMILIAR (hooks) ───────────────────────────────────────── -->
  <section class="section section--alt">
    <div class="container">
      <div class="sec-head text-center">
        <span class="eyebrow">Sound familiar?</span>
        <h2>If you’ve said any of these, it’s not bad luck. It’s a leak.</h2>
      </div>
      <div class="sf">
        <div class="sf__card"><p><span class="sf__q">“</span>Won the bid. Lost the margin.<span class="sf__q">”</span></p></div>
        <div class="sf__card"><p><span class="sf__q">“</span>The job was profitable — so where did the money go?<span class="sf__q">”</span></p></div>
        <div class="sf__card"><p><span class="sf__q">“</span>I’m financing my clients — for free.<span class="sf__q">”</span></p></div>
        <div class="sf__card"><p><span class="sf__q">“</span>Ghost labour shows up in my bank balance, not on site.<span class="sf__q">”</span></p></div>
        <div class="sf__card"><p><span class="sf__q">“</span>Every spreadsheet is a place money hides.<span class="sf__q">”</span></p></div>
        <div class="sf__card"><p><span class="sf__q">“</span>If everything needs my approval, nothing grows.<span class="sf__q">”</span></p></div>
      </div>
    </div>
  </section>

  <!-- ── THE 4 LEAKS ──────────────────────────────────────────────────── -->
  <section class="section" id="leaks">
    <div class="container">
      <div class="sec-head text-center">
        <span class="eyebrow">The 4 questions that decide your profit</span>
        <h2>Where is your money <span class="hl-ink">actually</span> leaking?</h2>
        <p class="lead" style="margin-inline:auto">
          You're not losing money on bad projects. You're losing it in the gaps —
          between the quote, the site and the collection. Here's each gap, and the part of sotyn.ai that closes it.
        </p>
      </div>

      <div class="leaks">
        {leaks.map((l) => (
          <article class="leak">
            <div class="leak__icon" aria-hidden="true"><Icon name={l.icon} size={26} /></div>
            <h3>“{l.q}”</h3>
            <p class="leak__problem"><strong>The leak:</strong> {l.leak}</p>
            <div class="leak__plug">
              <span class="dot" aria-hidden="true"></span>
              <p><strong>How sotyn.ai plugs it:</strong> {l.plug}</p>
            </div>
            <ul class="leak__mods">
              {l.modules.map((m) => <li>{m}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ── THESIS PULL-QUOTE (big hook) ─────────────────────────────────── -->
  <section class="thesis">
    <div class="container">
      <h2>You don’t have a profit problem.<br />You have a <span class="hl-w">visibility</span> problem.</h2>
      <p>You can’t fix a leak you can’t see. sotyn.ai makes every rupee visible — from quote to collection.</p>
    </div>
  </section>

  <!-- ── PROOF / DOGFOOD ──────────────────────────────────────────────── -->
  <section class="section section--dark" id="proof">
    <div class="container proof">
      <div class="proof__copy">
        <span class="eyebrow">Built by contractors, not coders</span>
        <h2>Most ERPs are sold by software companies. This one is sold by a contractor.</h2>
        <p class="lead">
          {SITE.parentCompany} is a 14-year-old EPC company. We got tired of losing
          money in the gaps — so we built sotyn.ai to run our own business first. Every module exists
          because a real jobsite problem demanded it.
        </p>
        <ul class="check-list" style="margin-top:8px">
          <li>Designed on real Indian project sites, not in a boardroom</li>
          <li>In plain language your site team actually uses</li>
          <li>Improved every week from our own daily use</li>
        </ul>
        <div class="btn-row" style="margin-top:26px">
          <a href="#demo" class="btn btn--white btn--lg">See it on your numbers</a>
        </div>
      </div>
      <div class="proof__stats">
        {SITE.stats.map((s) => (
          <div class="proof__stat"><strong>{s.value}</strong><span>{s.label}</span></div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── PUBLISHED AUTHOR / BOOKS (credibility) ───────────────────────── -->
  <section class="section" id="books">
    <div class="container">
      <div class="sec-head text-center">
        <span class="eyebrow">Published author</span>
        <h2>The hard-won lessons behind sotyn.ai — in print.</h2>
        <p class="lead" style="margin-inline:auto">Our founder didn't just build the software. He wrote the books on exactly where Indian projects lose money and time.</p>
        <div class="author">
          <img class="author__photo" src="/images/founder-ankur-kaplesh.jpg" alt="Er. Ankur Kaplesh" width="638" height="720" loading="lazy" />
          <div class="author__txt"><strong>Er. Ankur Kaplesh</strong><span>CMD &amp; Founder · TEDx Speaker · Published Author</span></div>
        </div>
      </div>
      <div class="books">
        <article class="book">
          <img class="book__cover" src="/images/book-11-deadly-facts.jpg" alt="Book cover: 11 Deadly Facts You Must Know to Save up to 27% of Your Project Value, by Er. Ankur Kaplesh" width="964" height="1500" loading="lazy" />
          <div class="book__body">
            <span class="pill">Bestseller on Amazon</span>
            <h3>11 Deadly Facts to Save up to 27% of Your Project Value</h3>
            <p>15+ years and 31,000+ on-site hours distilled into the exact checks that stop projects leaking money and time.</p>
            <a class="book__link" href="https://www.amazon.in/Deadly-Facts-value-project-Bestsellers/dp/8197111332" target="_blank" rel="noopener nofollow">View on Amazon <Icon name="arrow-right" size={16} /></a>
          </div>
        </article>
        <article class="book">
          <img class="book__cover" src="/images/book-autocad-to-site.jpg" alt="Book cover: From AutoCAD to Actual Site, by Er. Ankur Kaplesh" width="551" height="780" loading="lazy" />
          <div class="book__body">
            <span class="pill">New release</span>
            <h3>From AutoCAD to Actual Site</h3>
            <p>Why Indian buildings never match the drawing — 20 pain points and 20 solutions from the field.</p>
            <span class="book__link book__link--muted">Launching soon</span>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- ── LEAD MAGNET (free checklist) ─────────────────────────────────── -->
  <section class="section section--tint" id="checklist">
    <div class="container magnetband">
      <div class="magnetband__copy">
        <span class="eyebrow">Free download · from the founder's book</span>
        <h2>Get the 11-Point Project Savings Checklist</h2>
        <p class="lead">The exact checks our engineers run on every project — distilled from 15+ years and 31,000+ on-site hours. Grab it free before you sign your next contract.</p>
        <ul class="check-list" style="margin-top:6px">
          <li>Catch the delays that start before the work does</li>
          <li>Protect 25-year yield on every solar job</li>
          <li>The habits that quietly cut energy and rework cost</li>
        </ul>
        <p class="magnetband__tie">No credit card, no demo required — just the checklist. The same sotyn.ai team will be glad to help when you're ready.</p>
      </div>
      <div class="magnetband__form">
        <BookLeadMagnet source="home-checklist" />
      </div>
    </div>
  </section>

  <!-- ── AI-FIRST ─────────────────────────────────────────────────────── -->
  <section class="section section--dark" id="ai">
    <div class="container">
      <div class="sec-head text-center">
        <span class="eyebrow">Built AI-first</span>
        <h2>An ERP that doesn't just store your data — it <span class="ai__hl">thinks</span> about it.</h2>
        <p class="lead" style="margin-inline:auto">Most ERPs are filing cabinets. sotyn.ai watches every quote, site and rupee and tells you what needs attention — so problems reach you while you can still fix them.</p>
      </div>
      <div class="grid grid-4 ai">
        <div class="ai__card"><div class="ai__ic"><Icon name="bolt" size={24} /></div><h3>AI Auto-Quotation</h3><p>Accurate, margin-safe quotes in minutes from your own rates — not days of Excel.</p></div>
        <div class="ai__card"><div class="ai__ic"><Icon name="droplet" size={24} /></div><h3>AI leak alerts</h3><p>It flags where margin, material or cash is leaking — before month-end, not after.</p></div>
        <div class="ai__card"><div class="ai__ic"><Icon name="gauge" size={24} /></div><h3>AI daily briefing</h3><p>Every morning, the few numbers and risks that actually need you today — nothing else.</p></div>
        <div class="ai__card"><div class="ai__ic"><Icon name="chat" size={24} /></div><h3>Ask in plain language</h3><p>“Which projects are over budget?” Ask, and get the answer from your own live data.</p></div>
      </div>
    </div>
  </section>

  <!-- ── MODULES (suite breadth) ──────────────────────────────────────── -->
  <section class="section section--alt" id="modules">
    <div class="container">
      <div class="sec-head text-center">
        <span class="eyebrow">One login, the whole business</span>
        <h2>Everything from first lead to final rupee collected</h2>
        <p class="lead" style="margin-inline:auto">
          No more 7 disconnected apps and 30 Excel sheets. Quote, procurement, site, labour, billing
          and cash — all in one place, talking to each other.
        </p>
      </div>
      <div class="grid grid-3">
        {moduleGroups.map((g) => (
          <div class="card mod">
            <div class="mod__head"><span class="mod__icon" aria-hidden="true"><Icon name={g.icon} size={24} /></span><h3>{g.name}</h3></div>
            <ul class="mod__list">
              {g.items.map((i) => <li>{i}</li>)}
            </ul>
          </div>
        ))}
      </div>
      <p class="text-center muted" style="margin-top:28px">…plus a full Solar Division, Help Desk, Roles &amp; Permissions, Backups and AI settings.</p>
    </div>
  </section>

  <!-- ── MADE IN INDIA / DATA RESIDENCY (trust differentiator) ────────── -->
  <section class="section india">
    <div class="container india__in">
      <div class="india__copy">
        <span class="eyebrow">Made in India, for Indian contractors</span>
        <h2>Your data stays in India — and stays yours.</h2>
        <p class="lead">
          Built in India for the way Indian contractors actually work: GST, Tally, sub-contractor
          labour, site realities. Hosted in India, in your own secure workspace, with a full audit
          log. We never sell your data, and never share it with another contractor.
        </p>
        <div class="creds">
          {creds.map((c) => (
            <span class="cred"><Icon name="check" size={16} /> {c}</span>
          ))}
        </div>
      </div>
      <div class="india__pillars">
        <div class="pillar"><Icon name="shield" size={26} /><h3>Your data is yours</h3><p>Export any time. Never sold, never shared.</p></div>
        <div class="pillar"><Icon name="pin" size={26} /><h3>Hosted in India</h3><p>Indian data centres, Indian compliance.</p></div>
        <div class="pillar"><Icon name="layers" size={26} /><h3>One secure workspace</h3><p>Role-based access and a full audit trail.</p></div>
      </div>
    </div>
  </section>

  <!-- ── HOW IT WORKS ─────────────────────────────────────────────────── -->
  <section class="section section--alt" id="how">
    <div class="container">
      <div class="sec-head text-center">
        <span class="eyebrow">Live in weeks, not months</span>
        <h2>How you get started</h2>
      </div>
      <div class="grid grid-4 steps">
        {how.map((s) => (
          <div class="step">
            <div class="step__n">{s.n}</div>
            <h3>{s.t}</h3>
            <p class="muted">{s.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── LEAD TOOLS ───────────────────────────────────────────────────── -->
  <!-- ── BY THE NUMBERS (trust) ───────────────────────────────────────── -->
  <section class="section section--dark">
    <div class="container">
      <div class="sec-head text-center">
        <span class="eyebrow">The proof, in numbers</span>
        <h2>Numbers you can trust your business to.</h2>
        <p class="lead" style="margin-inline:auto">sotyn.ai isn't a startup experiment. It already runs a 14-year-old EPC business — at scale, every single day.</p>
      </div>
      <div class="nums">
        {SITE.trust.numbers.map((n) => (
          <div class="num"><strong>{n.value}</strong><span>{n.label}</span></div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── CAPABILITY & TRUST ───────────────────────────────────────────── -->
  <section class="section">
    <div class="container">
      <div class="sec-head text-center">
        <span class="eyebrow">Capability &amp; trust</span>
        <h2>Everything your business needs — built to be relied on.</h2>
        <p class="lead" style="margin-inline:auto">At ₹10,000 a month you're not buying software — you're getting the exact system a real EPC company runs on. Secured, supported, and proven on 535+ projects.</p>
      </div>
      <div class="grid grid-3 caps">
        {SITE.trust.capabilities.map((c) => (
          <div class="cap">
            <div class="cap__ic"><Icon name={c.icon} size={24} /></div>
            <h3>{c.t}</h3>
            <p class="muted">{c.d}</p>
          </div>
        ))}
      </div>
      <div class="certs2">
        {SITE.trust.certs.map((c) => (<span class="cert2"><Icon name="check" size={15} /> {c}</span>))}
      </div>
    </div>
  </section>

  <!-- ── LEAD TOOLS ───────────────────────────────────────────────────── -->
  <section class="section section--alt">
    <div class="container">
      <div class="sec-head text-center">
        <span class="eyebrow">Find your leaks — free</span>
        <h2>Two free ways to see where your money is going.</h2>
      </div>
      <div class="grid grid-2 ltools">
        <a href="/scorecard" class="ltool">
          <div class="ltool__ic"><Icon name="gauge" size={26} /></div>
          <h3>EPC Profit Leak Scorecard</h3>
          <p class="muted">Answer 7 questions, get your leak score and an estimate of how much you're losing a year — in 2 minutes.</p>
          <span class="ltool__cta">Take the scorecard <Icon name="arrow-right" size={16} /></span>
        </a>
        <a href="/tools" class="ltool">
          <div class="ltool__ic"><Icon name="wallet" size={26} /></div>
          <h3>Free EPC calculators</h3>
          <p class="muted">Quote margin, cash stuck in receivables, labour leakage — quick maths on your own numbers, no sign-up.</p>
          <span class="ltool__cta">Open the tools <Icon name="arrow-right" size={16} /></span>
        </a>
      </div>
    </div>
  </section>

  <!-- ── FAQ ──────────────────────────────────────────────────────────── -->
  <section class="section">
    <div class="container container--narrow">
      <div class="sec-head text-center">
        <span class="eyebrow">Straight answers</span>
        <h2>Questions contractors ask us</h2>
      </div>
      <div class="faqs">
        {faqs.map((f) => (
          <details class="faq">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ── FOUNDING URGENCY (countdown) ─────────────────────────────────── -->
  <section class="section section--alt">
    <div class="container container--narrow text-center">
      <span class="eyebrow">Founding offer</span>
      <h2>Lock ₹10,000/mo — for life.</h2>
      <p class="lead" style="margin-inline:auto">The first 100 EPC contractors lock the founding price forever. When the timer hits zero, the price goes up.</p>
      <div style="margin:26px 0 22px"><Countdown variant="light" /></div>
      <div class="btn-row" style="justify-content:center">
        <a href="/pricing" class="btn btn--primary btn--lg">See the founding offer</a>
        <a href="/scorecard" class="btn btn--ghost btn--lg">Get your free leak score</a>
      </div>
    </div>
  </section>

  <!-- ── DEMO / CTA ───────────────────────────────────────────────────── -->
  <section class="section section--dark" id="demo">
    <div class="container demo">
      <div class="demo__copy">
        <span class="eyebrow">Book a free demo</span>
        <h2>See exactly where you’re leaking money.</h2>
        <p class="lead">
          A 20-minute walkthrough on your own trades and project sizes. No slides, no jargon —
          just where your margin, cash and sites really stand. Then you decide.
        </p>
        <ul class="check-list" style="margin-top:6px">
          <li>Free, no obligation</li>
          <li>Tailored pricing for your team size — start small</li>
          <li>We migrate your Tally + Excel data for you</li>
        </ul>
        <p style="margin-top:22px">
          Prefer to talk now? <a href={waLink()} rel="nofollow" style="color:#fff;text-decoration:underline">WhatsApp us</a>
          or call <a href={`tel:${SITE.phoneHref}`} style="color:#fff;text-decoration:underline">{SITE.phone}</a>.
        </p>
      </div>
      <div class="demo__form">
        <DemoForm />
      </div>
    </div>
  </section>

  <script>
    const el = document.querySelector("[data-rotate]");
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (el && el.parentElement && !reduce) {
      const wrap = el.parentElement;
      const lines = [
        "Won the bid. Lost the margin. Found out at month-end.",
        "The job was profitable — so where did the money go?",
        "You paid for labour that never showed up on site.",
        "You’re financing your clients — for free.",
        "You can’t fix a leak you can’t see.",
      ];
      let i = 0;
      setInterval(() => {
        wrap.classList.add("is-fading");
        setTimeout(() => {
          i = (i + 1) % lines.length;
          el.textContent = lines[i];
          wrap.classList.remove("is-fading");
        }, 320);
      }, 2900);
    }
  </script>
</BaseLayout>

