---
import { SITE, waLink, telLink } from "../config/site";
const year = 2026;
---
<footer class="ft">
  <div class="container ft__in">
    <div class="ft__brand">
      <div class="ft__logo">
        <span class="ft__mark" aria-hidden="true">S</span>
        <span>sotyn<span>.ai</span></span>
      </div>
      <p class="ft__tag">{SITE.tagline}.</p>
      <p class="ft__by">By {SITE.parentCompany} — a live EPC company that runs its entire business on sotyn.ai.</p>
    </div>

    <nav class="ft__col" aria-label="Product">
      <h4>Product</h4>
      <a href="/features">Features</a>
      <a href="/pricing">Pricing</a>
      <a href="/about">About &amp; case study</a>
      <a href="/#leaks">Why it pays</a>
      <a href={SITE.appUrl} rel="nofollow">Customer login</a>
    </nav>

    <nav class="ft__col" aria-label="Company">
      <h4>Talk to us</h4>
      <a href={telLink}>{SITE.phone}</a>
      <a href={waLink()} rel="nofollow">WhatsApp</a>
      <a href={`mailto:${SITE.emailFallback}`}>{SITE.emailFallback}</a>
      <a href="/#demo">Book a demo</a>
    </nav>

    <div class="ft__col">
      <h4>Office</h4>
      <p class="ft__addr">{SITE.address.street},<br />{SITE.address.city}, {SITE.address.region} {SITE.address.postalCode}<br />{SITE.address.countryName}</p>
    </div>
  </div>

  <div class="container ft__bar">
    <p>© {year} {SITE.name} · {SITE.parentCompany}. All rights reserved.</p>
    <p class="ft__made">🇮🇳 Proudly built in India</p>
  </div>
</footer>

<style>
  .ft { background: var(--graphite-900); color: #94a3b8; padding-top: 64px; }
  .ft__in { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 36px; padding-bottom: 48px; }
  .ft__logo { display: flex; align-items: center; gap: 10px; font-weight: 800; font-size: 1.2rem; color: #fff; }
  .ft__logo span span { color: var(--brand-500); }
  .ft__mark { width: 30px; height: 30px; border-radius: 8px; display: grid; place-items: center; background: linear-gradient(135deg, var(--brand-600), var(--brand-500)); color: #fff; font-weight: 900; }
  .ft__tag { margin: 16px 0 8px; color: #cbd5e1; font-weight: 600; }
  .ft__by { font-size: .9rem; line-height: 1.6; max-width: 360px; margin: 0; }
  .ft__col h4 { color: #e5e7eb; font-size: .82rem; text-transform: uppercase; letter-spacing: .08em; margin-bottom: 16px; }
  .ft__col a { display: block; color: #94a3b8; padding: 6px 0; font-size: .95rem; }
  .ft__col a:hover { color: #fff; text-decoration: none; }
  .ft__addr { font-size: .92rem; line-height: 1.7; margin: 0; }
  .ft__bar { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; border-top: 1px solid rgba(255,255,255,.08); padding-top: 22px; padding-bottom: 28px; font-size: .85rem; }
  .ft__bar p { margin: 0; }
  @media (max-width: 860px) { .ft__in { grid-template-columns: 1fr 1fr; } .ft__brand { grid-column: 1 / -1; } }
  @media (max-width: 520px) { .ft__in { grid-template-columns: 1fr; } }
</style>
